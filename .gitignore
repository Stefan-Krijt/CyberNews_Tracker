# ===== CYBERNEWS TRACKER - .gitignore =====

# Python cache (always ignore)
__pycache__/
*.pyc

# Virtual environment (ignore if you use one)
venv/
.venv/
env/

# Environment variables (contains NewsAPI key, secret key)
.env
.env.local

# User data (sensitive - DO NOT COMMIT)
data/*.json
data/*.log
data/*.db-journal
!data/.gitkeep

# CVE database backup files (ignore backups, keep the main db if you want)
data/*.backup

# IDE files (if you use VSCode or PyCharm)
.vscode/
.idea/

# OS garbage files
.DS_Store
Thumbs.db

# Flask session files (if any)
flask_session/
instance/
